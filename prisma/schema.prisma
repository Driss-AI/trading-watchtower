// This is your Prisma schema file
// Learn more about it at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SETTINGS ───────────────────────────────────────────────────────────────

model Settings {
  id                  Int     @id @default(1)
  accountSize         Float   @default(50000)
  dailyLossLimit      Float   @default(1000)
  trailingDrawdown    Float   @default(2000)
  profitTarget        Float   @default(3000)
  maxTradesPerDay     Int     @default(2)
  maxLosingTradesPerDay Int   @default(2)
  mnqEnabled          Boolean @default(true)
  nqEnabled           Boolean @default(false)
  telegramBotToken    String? @default("")
  telegramChatId      String? @default("")
  tradingViewWebhookSecret String? @default("")
  // TopstepX scaffold — disabled until API docs provided
  topstepxApiKey      String? @default("")
  topstepxUsername    String? @default("")
  topstepxAccountId   String? @default("")
  topstepxBaseUrl     String? @default("https://api.topstepx.com")
  enableOrderExecution Boolean @default(false)

  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─── SESSIONS ────────────────────────────────────────────────────────────────

model Session {
  id              String   @id @default(cuid())
  date            String   // "YYYY-MM-DD"
  market          String   @default("MNQ")

  // Opening Range
  orHigh          Float?
  orLow           Float?
  orSize          Float?   // calculated: orHigh - orLow

  // Market Conditions
  directionBias   String   @default("neutral") // "bullish" | "bearish" | "neutral"
  hasHighImpactNews Boolean @default(false)
  newsNotes       String?  @default("")
  vixLevel        Float?
  vixExtreme      Boolean  @default(false)
  qqpAligned      Boolean  @default(false)
  us10yAgainst    Boolean  @default(false)
  dxyAgainst      Boolean  @default(false)
  cleanRoomToTarget Boolean @default(true)

  // Score
  score           Int      @default(0)
  decision        String   @default("NO_TRADE") // "TRADE" | "CAUTION" | "NO_TRADE"
  decisionReason  String   @default("")

  // Daily tracking
  dailyPnl        Float    @default(0)
  tradesCount     Int      @default(0)
  losesCount      Int      @default(0)

  // AI-written end-of-session debrief (Telegram + dashboard)
  debrief         String?

  trades          Trade[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date])
  @@map("sessions")
}

// ─── TRADES ──────────────────────────────────────────────────────────────────

model Trade {
  id            String   @id @default(cuid())
  sessionId     String
  session       Session  @relation(fields: [sessionId], references: [id])

  date          String   // "YYYY-MM-DD"
  time          String?  // "HH:MM"
  market        String   @default("MNQ")
  direction     String   // "LONG" | "SHORT"
  contracts     Int      @default(1)

  // Prices
  entry         Float
  stop          Float
  target        Float
  exit          Float?

  // Results
  resultPts     Float?   // exit - entry (for long), entry - exit (for short)
  resultDollars Float?   // net P&L (after fees)
  resultR       Float?   // resultPts / riskPts
  grossPnl      Float?   // gross P&L (before fees)
  tradeFees     Float?   // commissions / fees

  // Quality
  setupScore    Int?
  ruleFollowed  Boolean  @default(true)
  emotionLevel  Int?     // 1-5
  mistakeNotes  String?  @default("")
  notes         String?  @default("")

  // Status & source
  status        String   @default("OPEN") // "OPEN" | "WIN" | "LOSS" | "BE"
  source        String   @default("manual") // "manual" | "paper" | "topstepx"
  aiReasoning   String?  // AI brain's reasoning for this trade

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("trades")
}

// ─── WEBHOOK EVENTS ──────────────────────────────────────────────────────────

model WebhookEvent {
  id          String   @id @default(cuid())
  source      String   @default("tradingview")
  payload     String   // raw JSON string
  processed   Boolean  @default(false)
  alertSent   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("webhook_events")
}

// ─── ACCOUNT SNAPSHOTS ───────────────────────────────────────────────────────

model AccountSnapshot {
  id          String   @id @default(cuid())
  date        String   // "YYYY-MM-DD"
  balance     Float
  dailyPnl    Float    @default(0)
  totalPnl    Float    @default(0)
  source      String   @default("manual") // "manual" | "topstepx"
  createdAt   DateTime @default(now())

  @@map("account_snapshots")
}

// ─── TOPSTEPX SCAFFOLD ───────────────────────────────────────────────────────
// These tables are ready for when read-only API access is enabled

model BrokerConnection {
  id          String   @id @default(cuid())
  provider    String   @default("topstepx")
  status      String   @default("disconnected") // "connected" | "disconnected" | "error"
  lastSync    DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  @@map("broker_connections")
}

model SyncLog {
  id          String   @id @default(cuid())
  provider    String   @default("topstepx")
  action      String
  status      String   // "success" | "error"
  message     String?
  createdAt   DateTime @default(now())

  @@map("sync_logs")
}

// ─── SIGNAL OPPORTUNITY ──────────────────────────────────────────────────────
// One row per OR-buffer crossing evaluated by the signal engine, taken or
// skipped. The data asset that makes AI-vs-mechanical attribution, would-have
// outcomes, and learning queries possible.

model SignalOpportunity {
  id        String   @id @default(cuid())

  // Identity
  date      String   // YYYY-MM-DD (NY date)
  barTime   DateTime // close-of-bar timestamp (UTC)
  market    String   @default("MNQ")
  direction String   // LONG / SHORT

  // OR + entry math
  orHigh        Float
  orLow         Float
  orSize        Float
  refPrice      Float
  entry         Float
  stop          Float
  target        Float
  riskPts       Float
  rewardPts     Float
  rrRatio       Float

  // Structural context (nullable — filled when available)
  vwap          Float?
  vwapDistance  Float?
  priorDayHigh  Float?
  priorDayLow   Float?
  overnightHigh Float?
  overnightLow  Float?

  // Pattern gate
  patternName     String?
  patternVerdict  String?  // confirm | caution | neutral | veto
  patternSignal   String?  // bullish | bearish | neutral | caution
  patternStrength Int?
  orbContext      String?

  // Volume gate
  volumeRatio     Float?
  volumeVerdict   String?  // confirm | caution | neutral | veto
  breakVolume     Int?
  avgVolume       Float?

  // Order-flow gate
  orderflowVerdict   String?  // confirm | caution | veto
  orderflowAvailable Boolean  @default(false)
  cumDeltaAtBreak    Int?
  shortDeltaAtBreak  Int?
  deltaDivergence    String?  // none | mild | strong
  wallRisk           String?  // none | moderate | high

  // Raw gate verdicts (for replay / future re-analysis)
  gateVerdictsJson Json

  // Freshness flags (audit + replay)
  candleFreshness    String   // fresh | stale | missing
  orderflowFreshness String
  macroFreshness     String
  accountFreshness   String

  // Mechanical layer
  mechanicalVerdict   String   // take | caution | skip
  mechanicalContracts Int
  hardCap             Int

  // AI layer
  aiStatus       String?   // ok | unavailable | skipped
  aiModel        String?
  aiEnter        Boolean?
  aiConfidence   Int?
  aiContracts    Int?
  aiVetoTake     Boolean?
  aiVetoReason   String?
  aiReasoning    String?

  // Final decision
  finalDecision   String    // take | skip
  finalContracts  Int       @default(0)
  skipReason      String?
  skipSource      String?   // mechanical | ai-veto | ai-uncertain | ai-unavailable
  rationale       String?

  // Linked trade (when taken)
  paperTradeId    String?   @unique

  // Manual-execution validity (computed at signal time — a hand-placed order
  // needs a shelf life). See lib/signal-engine/finalize.ts.
  priceAtSignal      Float?
  signalExpiresAt    DateTime?
  validForSeconds    Int?
  maxChaseDistance   Float?
  cancelIfBeyond     Float?
  entryBandLow       Float?
  entryBandHigh      Float?

  // Manual execution tracking (filled when the user logs their real action)
  manualExecutionStatus String  @default("NOT_TAKEN") // NOT_TAKEN | TAKEN | SKIPPED | MISSED | CANCELLED | EXPIRED
  actualEntry           Float?
  actualContracts       Int?
  priceAtExecution      Float?
  executionDelaySeconds Int?
  manualOverrideReason  String?
  expiredReason         String?
  executedAt            DateTime?

  // Outcome (resolved later — taken trade closes OR skipped trade window expires)
  outcomeStatus   String    @default("pending")  // pending | resolved
  outcomeLabel    String?   // win | loss | be | inconclusive
  outcomeR        Float?
  mfeR            Float?
  maeR            Float?
  wouldEntry      Float?    // for skipped trades
  wouldStop       Float?
  wouldTarget     Float?
  resolvedAt      DateTime?

  source          String    @default("paper")  // paper | backtest | live-signal
  createdAt       DateTime  @default(now())

  @@index([date, market])
  @@index([finalDecision, outcomeLabel])
  @@index([source, date])
  @@map("signal_opportunities")
}
