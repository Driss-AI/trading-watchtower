# ─── TRADING WATCHTOWER — ENVIRONMENT VARIABLES ─────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it is in .gitignore

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL service
# For local dev: postgresql://USER:PASSWORD@localhost:5432/trading_watchtower
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/trading_watchtower"

# ─── TELEGRAM ────────────────────────────────────────────────────────────────
# Create a bot at https://t.me/BotFather and get the token
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ─── TRADINGVIEW WEBHOOK ─────────────────────────────────────────────────────
# Set this secret in your TradingView Pine Script alert message as "secret"
TRADINGVIEW_WEBHOOK_SECRET="change-me-to-something-secret"

# ─── TOPSTEPX API (SCAFFOLD — NOT ACTIVE) ────────────────────────────────────
# Leave these blank for now — fill in Phase 3 when you have API credentials
TOPSTEPX_API_KEY=""
TOPSTEPX_API_SECRET=""
TOPSTEPX_ACCOUNT_ID=""
TOPSTEPX_BASE_URL="https://api.topstepx.com"
TOPSTEPX_WS_URL="wss://api.topstepx.com"

# ─── SAFETY LOCK ─────────────────────────────────────────────────────────────
# THIS MUST ALWAYS BE FALSE — ORDER EXECUTION IS NOT ALLOWED IN V1
ENABLE_ORDER_EXECUTION=false

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
