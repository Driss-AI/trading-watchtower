# ─── TRADING WATCHTOWER — ENVIRONMENT VARIABLES ──────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it is in .gitignore

# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/trading_watchtower"

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────
# Create bot at https://t.me/BotFather | Get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ─── TOPSTEPX / PROJECTX API ──────────────────────────────────────────────────
# Get API key from TopstepX → Settings → API tab
# Username = your TopstepX login email
TOPSTEPX_USERNAME=""
TOPSTEPX_API_KEY=""
TOPSTEPX_ACCOUNT_ID=""
TOPSTEPX_BASE_URL="https://api.topstepx.com"

# Optional: pin specific contract IDs (otherwise auto-detected)
# TOPSTEPX_NQ_CONTRACT_ID="CON.F.US.NQ.M26"
# TOPSTEPX_MNQ_CONTRACT_ID="CON.F.US.MNQ.M26"

# ─── SAFETY LOCK ──────────────────────────────────────────────────────────────
# THIS MUST ALWAYS BE FALSE — ORDER EXECUTION IS NOT ALLOWED
ENABLE_ORDER_EXECUTION=false

# ─── APP ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
